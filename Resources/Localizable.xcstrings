    "Drag the control wheel to move the simulated point. Push farther to move faster, up to the configured speed. Release to stop." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖动控制轮以移动模拟点。推得越远，移动速度越快，最高可达设定速度。松开即可停止。"
          }
        }
      }
    },
    "Drawn" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "绘制"
          }
        }
      }
    },
    "Enable Developer Mode on the iPhone in Settings > Privacy & Security > Developer Mode." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请在 iPhone 的“设置 > 隐私与安全性 > 开发者模式”中启用开发者模式。"
          }
        }
      }
    },
    "Enter valid coordinates before starting movement." : {
