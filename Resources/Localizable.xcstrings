        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "经度"
          }
        }
      }
    },
    "macOS will ask for your administrator password in a separate system dialog when the physical-device tunnel starts." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当真机隧道启动时，macOS 会在单独的系统对话框中请求你的管理员密码。"
          }
        }
      }
    },
    "Manual Coordinates" : {
      "localizations" : {
        "zh-Hans" : {
