            "value" : "固定间隔"
          }
        }
      }
    },
    "For Wi-Fi discovery, connect once over USB first, accept pairing, then keep the iPhone unlocked on the same local network." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要通过 Wi‑Fi 发现设备，请先通过 USB 连接一次并接受配对，然后保持 iPhone 解锁并连接到同一局域网。"
          }
        }
      }
    },
    "Found %lld device(s)." : {
