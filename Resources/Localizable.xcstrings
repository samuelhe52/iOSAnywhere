{
  "sourceLanguage" : "en",
  "strings" : {
    "" : {

    },
    "%@ · iOS %@" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ · iOS %2$@"
          }
        }
      }
    },
    "%lld" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%lld"
          }
        }
      }
    },
    "%lld / %lld" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld / %2$lld"
          }
          },
          "zh-Hans" : {
            "stringUnit" : {
              "state" : "translated",
              "value" : "%1$lld / %2$lld"
            }
        }
      }
    },
    "`xcrun` is not guaranteed to be usable on a clean macOS install. If macOS reports missing developer tools, install them with `xcode-select --install`. If full Xcode is already installed but the active developer directory is wrong, run `sudo xcode-select -s /Applications/Xcode.app/Contents/Developer`, then launch Xcode once to finish setup." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在全新 macOS 安装上，`xcrun` 不一定可用。如果 macOS 提示缺少开发者工具，请运行 `xcode-select --install` 安装。如果已安装完整 Xcode 但当前开发者目录不正确，请运行 `sudo xcode-select -s /Applications/Xcode.app/Contents/Developer`，然后启动一次 Xcode 以完成设置。"
          }
        }
      }
    },
    "0.10s" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "0.10s"
          }
        }
      }
    },
    "1x" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1x"
          }
        }
      }
    },
    "2.00s" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2.00s"
          }
        }
      }
    },
    "32x" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "32x"
          }
        }
      }
    },
    "Actions" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "操作"
          }
        }
      }
    },
    "Administrator approval is required for physical-device simulation." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "真机模拟需要管理员授权。"
          }
        }
      }
    },
    "Administrator approval was canceled before the macOS password prompt." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 macOS 密码提示出现前，管理员授权已取消。"
          }
        }
      }
    },
    "Administrator approval was canceled. Physical-device location simulation did not start." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "管理员授权已取消。真机位置模拟未启动。"
          }
        }
      }
    },
    "Administrator Password" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "管理员密码"
          }
        }
      }
    },
    "Advance every waypoint on a fixed clock regardless of GPX timestamps." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无论 GPX 时间戳如何，都按固定时间间隔推进每个航点。"
          }
        }
      }
    },
    "Apple location search is temporarily unavailable." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apple 位置搜索暂时不可用。"
          }
        }
      }
    },
    "Authorize" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "授权"
          }
        }
      }
    },
    "Authorize physical-device location simulation. Your password is handled by macOS and is not stored by Teleport." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "为真机位置模拟授权。你的密码由 macOS 处理，Teleport 不会存储该密码。"
          }
        }
      }
    },
    "Before simulating location on a physical iPhone, confirm the device and host are ready." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在为真机 iPhone 模拟位置之前，请确认设备和主机已准备就绪。"
          }
        }
      }
    },
    "Cancel" : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "取消"
